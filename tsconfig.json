{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@texisstudio/plugin-contracts": ["./visual-plugins/common/contracts/index.ts"],
      "@texisstudio/plugin-manifest": ["./visual-plugins/common/manifest/index.ts"],
      "@texisstudio/plugin-validation": ["./visual-plugins/common/validation/index.ts"],
      "@texisstudio/plugin-export": ["./visual-plugins/common/export/index.ts"]
    }
  },
  "include": ["visual-plugins/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
